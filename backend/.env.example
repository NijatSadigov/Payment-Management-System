# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/payment_management?schema=public"

# Secret used to sign JWT tokens (use a long random string in production)
JWT_SECRET="change-this-to-a-long-random-secret"

# Token lifetime
JWT_EXPIRES_IN="7d"

# Port the Express server listens on
PORT=3000

# Absolute base URL of this app (used by the live gateway for redirects/callbacks)
APP_BASE_URL=http://localhost:3000

# ----- Epoint online-payment gateway (epoint.az) -----
# "sandbox" uses a built-in simulated gateway (no real money, works out of the box).
# Set EPOINT_MODE=live and paste the merchant keys from your Epoint account to go live.
# In live mode, set your Epoint "Result URL" to:  <APP_BASE_URL>/api/epay/epoint-callback
EPOINT_MODE=sandbox
EPOINT_PUBLIC_KEY=SANDBOX-PUBLIC-KEY
EPOINT_PRIVATE_KEY=sandbox-private-key-change-me
EPOINT_BASE_URL=https://epoint.az/api/1
EPOINT_CURRENCY=AZN
